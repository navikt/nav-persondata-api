# Lokale hemmeligheter for nav-persondata-api
#
# Kopier denne filen til .env.local.properties og fyll inn verdiene:
#   cp .env.local.properties.example .env.local.properties
#
# Hent verdier automatisk fra dev-gcp (krever kubectl-tilgang):
#   ./get-secrets.sh

# Azure AD — fra Kubernetes secret "azure-nav-persondata-api-*" i namespace holmes
AZURE_APP_CLIENT_ID=
AZURE_APP_CLIENT_SECRET=

# Valkey (Redis) — fra Kubernetes secret "aiven-valkey-nav-persondata-api-*" i namespace holmes
VALKEY_HOST_NAV_PERSONDATA_API=
VALKEY_PORT_NAV_PERSONDATA_API=
VALKEY_USERNAME_NAV_PERSONDATA_API=
VALKEY_PASSWORD_NAV_PERSONDATA_API=
